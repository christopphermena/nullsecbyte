---
import { PROCESS_STEPS } from '../../constants'
import Section from '../ui/Section.astro'
import Container from '../ui/Container.astro'
import SectionHeader from '../ui/SectionHeader.astro'
---

<Section id="proceso" ariaLabelledby="process-title" background="gradient">
  <Container>
    <SectionHeader
      label="Cómo trabajo"
      title="Simple, directo y sin rodeos"
      description="Un proceso claro para que sepas exactamente qué esperar en cada etapa."
      id="process-title"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
      {PROCESS_STEPS.map((step, i) => (
        <div class="relative fade-up">
          <div class="bg-card border border-border rounded-[--radius-lg] p-6 transition-all duration-[0.22s] hover:-translate-y-[2px] hover:border-primary/20 hover:shadow-[0_8px_32px_-8px_rgba(99,102,241,0.1)]">
            <div class={`w-10 h-10 rounded-[--radius-md] flex items-center justify-center text-sm font-bold mb-4 text-white ${
              i === 0 ? 'gradient-bg' : i === 1 ? 'gradient-bg-cyan' : i === 2 ? 'gradient-bg-warm' : 'gradient-bg'
            }`}>
              {step.step}
            </div>
            <h3 class="text-[0.95rem] font-bold text-text-primary mb-2">{step.title}</h3>
            <p class="text-sm text-text-secondary leading-[1.65]">{step.description}</p>
          </div>
          {step.step < PROCESS_STEPS.length && (
            <div class="hidden lg:block absolute top-1/2 -right-3 w-6 h-[2px] bg-gradient-to-r from-primary/30 to-secondary/30"></div>
          )}
        </div>
      ))}
    </div>
  </Container>
</Section>
