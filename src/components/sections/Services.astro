---
import { SERVICES } from '../../constants'
import Section from '../ui/Section.astro'
import Container from '../ui/Container.astro'
import SectionHeader from '../ui/SectionHeader.astro'

const icons: Record<string, string> = {
  layout: '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
  palette: '<circle cx="13.5" cy="6.5" r="4.5"/><circle cx="6" cy="18" r="3"/><path d="M17 21a3 3 0 0 1-3-3v-8"/><path d="M17 12a3 3 0 0 1 0 6"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  zap: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>',
  search: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  smartphone: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
}
---

<Section id="lo-que-construyo" ariaLabelledby="services-title" background="surface">
  <Container>
    <SectionHeader
      label="✨ Lo que construyo"
      title="De la idea al navegador"
      description="Diseño, desarrollo y optimización de Landing Pages modernas que convierten visitantes en clientes."
      id="services-title"
    />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {SERVICES.map((service, i) => (
        <article class="bg-card border border-border rounded-[--radius-lg] p-7 transition-all duration-[0.22s] ease-in-out hover:-translate-y-[2px] hover:border-primary/20 hover:shadow-[0_8px_32px_-8px_rgba(99,102,241,0.12)] fade-up">
          <div class={`w-10 h-10 rounded-[--radius-md] border flex items-center justify-center mb-4 ${i % 3 === 0 ? 'bg-primary/10 border-primary/20 text-primary' : i % 3 === 1 ? 'bg-accent/10 border-accent/20 text-accent' : 'bg-accent-soft/10 border-accent-soft/20 text-accent-soft'}`}>
            <svg class="w-5 h-5 stroke-current fill-none stroke-[1.75] stroke-linecap-round stroke-linejoin-round" viewBox="0 0 24 24" aria-hidden="true">
              {icons[service.icon] && <Fragment set:html={icons[service.icon]} />}
            </svg>
          </div>
          <h3 class="text-[1.05rem] font-bold text-text-primary mb-2">{service.title}</h3>
          <p class="text-sm text-text-secondary leading-[1.65]">{service.description}</p>
        </article>
      ))}
    </div>
  </Container>
</Section>
