---
import { TECH_ITEMS } from '../../constants'
import Section from '../ui/Section.astro'
import Container from '../ui/Container.astro'
import SectionHeader from '../ui/SectionHeader.astro'
---

<Section id="herramientas" ariaLabelledby="tech-title" background="surface">
  <Container>
    <SectionHeader
      label="🧰 Herramientas favoritas"
      title="Tecnologías que uso a diario"
      description="Stack moderno para construir landing pages rápidas, seguras y bonitas."
      id="tech-title"
    />
    <div class="flex flex-wrap justify-center gap-3">
      {TECH_ITEMS.map((item, i) => (
        <div class={`border rounded-[--radius-md] px-5 py-3 transition-all duration-[0.22s] hover:-translate-y-[1px] fade-up ${
          i % 3 === 0
            ? 'bg-primary/10 border-primary/20 text-primary-light hover:shadow-[0_0_20px_rgba(99,102,241,0.15)]'
            : i % 3 === 1
            ? 'bg-accent/10 border-accent/20 text-accent hover:shadow-[0_0_20px_rgba(34,211,238,0.15)]'
            : 'bg-accent-soft/10 border-accent-soft/20 text-accent-soft hover:shadow-[0_0_20px_rgba(244,114,182,0.15)]'
        }`}>
          <span class="text-sm font-semibold">{item.name}</span>
          <span class="text-[0.6rem] font-medium opacity-60 ml-2 uppercase tracking-wider">{item.category}</span>
        </div>
      ))}
    </div>
  </Container>
</Section>
