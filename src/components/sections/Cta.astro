---
import { SITE } from '../../constants'
import Button from '../ui/Button.astro'
import Container from '../ui/Container.astro'
---

<section id="contacto" aria-labelledby="cta-title" class="py-20 md:py-28 bg-base relative overflow-hidden">
  <div class="blob w-[500px] h-[500px] bg-primary/10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
  <div class="blob w-[300px] h-[300px] bg-accent-soft/8 top-0 right-0"></div>
  <div class="blob w-[300px] h-[300px] bg-accent/8 bottom-0 left-0"></div>
  <Container>
    <div class="relative z-10 text-center bg-card border border-border rounded-[--radius-xl] px-8 py-16 md:py-20 max-w-[680px] mx-auto shadow-[0_20px_60px_-16px_rgba(0,0,0,0.3)] fade-up">
      <p class="text-xs font-semibold tracking-[0.16em] uppercase text-primary mb-4">🤝 Trabajemos juntos</p>
      <h2 id="cta-title" class="text-[clamp(2rem,4.5vw,3.2rem)] font-black leading-[1.1] tracking-[-0.025em] text-text-primary mb-4">
        ¿Tienes un proyecto<br />
        <span class="gradient-text">en mente?</span>
      </h2>
      <p class="text-text-secondary text-lg leading-[1.7] mb-8 max-w-[480px] mx-auto">
        Cuéntame tu idea y te enviaré una propuesta clara sin compromiso. Sin vueltas, solo trabajo bien hecho.
      </p>
      <div class="flex flex-col sm:flex-row gap-3.5 justify-center">
        <Button href={`mailto:${SITE.email}`} variant="primary" size="lg" ariaLabel="Enviar un correo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Enviar correo
        </Button>
        <Button href="#tutoriales" variant="ghost" size="lg">
          Explorar contenido gratis
        </Button>
      </div>
      <p class="text-[0.75rem] text-text-muted mt-4">Respuesta en menos de 24 horas</p>
    </div>
  </Container>
</section>
