---
import { SITE } from '../../constants'
import Section from '../ui/Section.astro'
import Container from '../ui/Container.astro'
import SectionHeader from '../ui/SectionHeader.astro'
---

<Section id="tutoriales" ariaLabelledby="tutorials-title" background="gradient">
  <Container>
    <SectionHeader
      label="📱 Sígueme"
      title="Aprende conmigo en redes"
      description="Contenido gratuito sobre desarrollo web, diseño y optimización. Todos los días hay nuevo contenido."
      id="tutorials-title"
    />
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5" id="social-grid">
      <a
        href={SITE.social.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-card border border-border rounded-[--radius-xl] overflow-hidden transition-all duration-[0.22s] ease-in-out hover:-translate-y-[2px] hover:border-red-500/30 hover:shadow-[0_8px_32px_-8px_rgba(255,0,0,0.15)] fade-up group"
      >
        <div id="youtube-thumb" class="aspect-video bg-gradient-to-br from-red-600/20 via-red-500/10 to-red-700/20 flex items-center justify-center border-b border-border relative overflow-hidden">
          <div class="w-14 h-14 rounded-full bg-red-500/20 flex items-center justify-center group-hover:scale-110 transition-all duration-[0.22s]">
            <svg class="w-7 h-7 text-red-500" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </div>
        </div>
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <h3 class="text-[1rem] font-bold text-text-primary">YouTube</h3>
          </div>
          <p class="text-xs text-text-secondary leading-[1.6]">Tutoriales completos de desarrollo web, diseño y optimización.</p>
        </div>
      </a>

      <a
        href={SITE.social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-card border border-border rounded-[--radius-xl] overflow-hidden transition-all duration-[0.22s] ease-in-out hover:-translate-y-[2px] hover:border-pink-500/30 hover:shadow-[0_8px_32px_-8px_rgba(236,72,153,0.15)] fade-up group"
      >
        <div class="aspect-video bg-gradient-to-br from-pink-600/20 via-purple-500/10 to-orange-500/20 flex items-center justify-center border-b border-border relative overflow-hidden">
          <div class="w-14 h-14 rounded-full bg-pink-500/20 flex items-center justify-center group-hover:scale-110 transition-all duration-[0.22s]">
            <svg class="w-7 h-7 text-pink-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </div>
        </div>
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-pink-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <h3 class="text-[1rem] font-bold text-text-primary">Instagram</h3>
          </div>
          <p class="text-xs text-text-secondary leading-[1.6]">Contenido visual, tips rápidos y detrás de escena de cada proyecto.</p>
        </div>
      </a>

      <a
        href={SITE.social.tiktok}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-card border border-border rounded-[--radius-xl] overflow-hidden transition-all duration-[0.22s] ease-in-out hover:-translate-y-[2px] hover:border-gray-100/30 hover:shadow-[0_8px_32px_-8px_rgba(255,255,255,0.1)] fade-up group"
      >
        <div class="aspect-video bg-gradient-to-br from-gray-800/30 via-gray-700/10 to-gray-900/30 flex items-center justify-center border-b border-border relative overflow-hidden">
          <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center group-hover:scale-110 transition-all duration-[0.22s]">
            <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </div>
        </div>
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            <h3 class="text-[1rem] font-bold text-text-primary">TikTok</h3>
          </div>
          <p class="text-xs text-text-secondary leading-[1.6]">Tips rápidos, tricks de código y contenido directo al grano.</p>
        </div>
      </a>
    </div>

    <div class="text-center mt-10 fade-up">
      <p class="text-sm text-text-muted">Contenido nuevo cada semana. ¡No te pierdas nada!</p>
    </div>
  </Container>
</Section>

<script>
  async function loadLatestYouTubeVideo() {
    const thumb = document.getElementById('youtube-thumb')
    if (!thumb) return

    const apiKey = import.meta.env.PUBLIC_YOUTUBE_API_KEY
    const handle = '@nullsecbyte'

    if (!apiKey) return

    try {
      const channelRes = await fetch(
        `https://www.googleapis.com/youtube/v3/channels?part=id&forHandle=${handle}&key=${apiKey}`
      )
      if (!channelRes.ok) return
      const channelData = await channelRes.json()
      if (!channelData.items?.length) return
      const channelId = channelData.items[0].id

      const videoRes = await fetch(
        `https://www.googleapis.com/youtube/v3/search?order=date&part=snippet&channelId=${channelId}&maxResults=1&type=video&key=${apiKey}`
      )
      if (!videoRes.ok) return
      const videoData = await videoRes.json()
      if (!videoData.items?.length) return

      const video = videoData.items[0]
      const thumbnail = video.snippet.thumbnails.maxres?.url || video.snippet.thumbnails.high?.url
      const videoUrl = `https://youtube.com/watch?v=${video.id.videoId}`

      if (thumbnail) {
        thumb.innerHTML = `
          <img src="${thumbnail}" alt="${video.snippet.title}" class="w-full h-full object-cover absolute inset-0" loading="lazy" />
          <div class="absolute inset-0 bg-black/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-[0.22s]">
            <div class="w-14 h-14 rounded-full bg-red-600/90 flex items-center justify-center">
              <svg class="w-7 h-7 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          </div>
        `
        thumb.closest('a')?.addEventListener('click', (e) => {
          e.preventDefault()
          window.open(videoUrl, '_blank', 'noopener,noreferrer')
        })
      }
    } catch {
      // fallback: keep the default play icon
    }
  }

  loadLatestYouTubeVideo()
</script>

<style>
  #youtube-thumb img {
    transition: transform 0.3s ease;
  }
  .group:hover #youtube-thumb img {
    transform: scale(1.05);
  }
</style>
