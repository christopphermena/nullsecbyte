---
export interface Props {
  class?: string
  as?: 'section' | 'div'
  id?: string
  ariaLabelledby?: string
}

const { class: className, as: Tag = 'div', id, ariaLabelledby } = Astro.props
---

<Tag id={id} class={`w-full max-w-[1120px] mx-auto px-6 ${className ?? ''}`} aria-labelledby={ariaLabelledby}>
  <slot />
</Tag>
