---
import { cn } from '../../utils/cn'

export interface Props {
  href?: string
  variant?: 'primary' | 'secondary' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  class?: string
  target?: string
  rel?: string
  ariaLabel?: string
}

const { href, variant = 'primary', size = 'md', class: className, target, rel, ariaLabel } = Astro.props

const Tag = href ? 'a' : 'button'
const base = 'inline-flex items-center justify-center gap-2 font-semibold tracking-[0.01em] rounded-[--radius-md] transition-all duration-[0.22s] ease-in-out no-underline whitespace-nowrap focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-[3px]'
const variants = {
  primary: 'gradient-bg text-white hover:shadow-[0_0_28px_rgba(99,102,241,0.35)] hover:-translate-y-[1px] active:translate-y-0',
  secondary: 'bg-card text-primary border border-primary/30 hover:border-primary hover:shadow-[0_0_20px_rgba(99,102,241,0.15)] hover:-translate-y-[1px]',
  ghost: 'bg-transparent text-text-secondary border border-border hover:border-primary/30 hover:text-primary hover:bg-white/[0.03]',
}
const sizes = {
  sm: 'text-xs px-3 py-1.5',
  md: 'text-sm px-5 py-2.5',
  lg: 'text-base px-7 py-3.5',
}
---

<Tag
  href={href}
  class={cn(base, variants[variant], sizes[size], className)}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
>
  <slot />
</Tag>
