---
import { SITE } from '../../constants'
---

<footer id="footer" role="contentinfo" class="bg-surface border-t border-border py-12 md:py-16">
  <div class="container max-w-[1120px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr_1fr] gap-10 pb-10 border-b border-border">
      <div class="footer-brand">
        <a href="/" class="flex items-center gap-2.5 flex-shrink-0 mb-3" aria-label={`${SITE.name} - Inicio`}>
          <img src="/logo.svg" alt={SITE.name} class="w-9 h-9" />
          <span class="text-[1.05rem] font-extrabold text-text-primary tracking-[-0.02em]">{SITE.name}</span>
        </a>
        <p class="text-sm text-text-muted leading-[1.7] max-w-[280px]">
          Landing Pages modernas, tutoriales de desarrollo web y diseño. Comparto todo el proceso para que aprendas o trabajemos juntos.
        </p>
      </div>

      <nav class="footer-col" aria-label="Secciones">
        <h4 class="text-[0.75rem] font-bold tracking-[0.1em] uppercase text-text-muted mb-4">Navegación</h4>
        <ul class="flex flex-col gap-2.5">
          <li><a href="#lo-que-construyo" class="text-sm text-text-muted transition-colors duration-[0.22s] hover:text-text-primary">Lo que construyo</a></li>
          <li><a href="#tutoriales" class="text-sm text-text-muted transition-colors duration-[0.22s] hover:text-text-primary">Tutoriales</a></li>
          <li><a href="#sobre-mi" class="text-sm text-text-muted transition-colors duration-[0.22s] hover:text-text-primary">Sobre mí</a></li>
          <li><a href="#faq" class="text-sm text-text-muted transition-colors duration-[0.22s] hover:text-text-primary">Preguntas frecuentes</a></li>
        </ul>
      </nav>

      <div class="footer-col">
        <h4 class="text-[0.75rem] font-bold tracking-[0.1em] uppercase text-text-muted mb-4">Conéctate</h4>
        <ul class="flex flex-col gap-2.5">
          {SITE.social.youtube && (
            <li><a href={SITE.social.youtube} target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors duration-[0.22s] hover:text-text-primary">YouTube</a></li>
          )}
          {SITE.social.instagram && (
            <li><a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors duration-[0.22s] hover:text-text-primary">Instagram</a></li>
          )}
          {SITE.social.tiktok && (
            <li><a href={SITE.social.tiktok} target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors duration-[0.22s] hover:text-text-primary">TikTok</a></li>
          )}
        </ul>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-3 pt-7">
      <p class="text-[0.75rem] text-text-muted">
        © <span id="year"></span> {SITE.name}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = String(new Date().getFullYear())
</script>
